# --- Game database (your Metin2 server's MySQL / MariaDB) ---
# The item catalog is read live from the `player.item_proto` table.
NUXT_DB_HOST=127.0.0.1
NUXT_DB_PORT=3306
NUXT_DB_USER=root
NUXT_DB_PASSWORD=
NUXT_DB_DATABASE=player

# --- Game files (icons, names, descriptions) ---
# Your client's pack dir (the folder that contains locale_*, ETC/, icon/, ...).
M2_PACK_DIR=../client/bin/pack
# Your server's conf dir holding item_names_en.txt / item_names_ru.txt.
M2_NAMES_DIR=../server/gamefiles/conf
# Optional override (defaults to <M2_PACK_DIR>/locale_en/locale/en/item_list.txt):
# M2_ITEM_LIST=
